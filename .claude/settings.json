{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "devpulse record --tool $TOOL_USE_TOOL_NAME --file \"$TOOL_USE_INPUT_FILE_PATH\" 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "devpulse check 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "devpulse start 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
